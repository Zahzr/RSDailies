{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "section.schema.json",
  "title": "Tracker Section Definition",
  "type": "object",
  "required": ["id", "label", "renderVariant"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "label": { "type": "string", "minLength": 1 },
    "legacySectionId": { "type": "string" },
    "renderVariant": { "type": "string", "minLength": 1 },
    "items": {
      "type": "array",
      "items": { "$ref": "task.schema.json" }
    },
    "groups": {
      "type": "array",
      "items": { "type": "object" }
    }
  },
  "additionalProperties": true
}
